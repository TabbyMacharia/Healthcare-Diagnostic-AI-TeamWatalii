    # ────────────────────────────────────────────────────────
    def __init__(self, laplace_alpha: float = 0.01):
        """
        Parameters
        ----------
        laplace_alpha : float
            Smoothing value for unseen symptoms.
            Prevents log(0) without distorting probabilities.
        """
        self.priors      = dict(self.BASE_PRIORS)
        self.likelihoods = {d: dict(lk) for d, lk in self.LIKELIHOODS.items()}
        self.alpha       = laplace_alpha
        self._history: List[DiagnosisResult] = []

    # ── Core Inference ───────────────────────────────────────
    def compute_posterior(
        self,
        symptoms: List[str],
        use_weights: bool = True,
        custom_priors: Optional[Dict[str, float]] = None,
    ) -> Dict[str, float]:
        """
        Compute P(Disease | Symptoms) using log-space Naïve Bayes.

        P(D|S₁..Sₙ) ∝ P(D) × ∏ P(Sᵢ|D)^wᵢ

        Parameters
        ----------
        symptoms      : observed symptom list
        use_weights   : apply CRITICAL_WEIGHTS for key symptoms
        custom_priors : override default priors (e.g., post-history update)
        """
        priors   = custom_priors if custom_priors else self.priors
        symptoms = [s.lower().replace(' ', '_') for s in symptoms]

        log_posteriors = {}
        for disease, prior in priors.items():
            log_p = np.log(prior + 1e-12)
            for symptom in symptoms:
                likelihood = self.likelihoods[disease].get(symptom, self.alpha)
                weight     = (self.CRITICAL_WEIGHTS.get(symptom, 1.0)
                              if use_weights else 1.0)
                log_p += weight * np.log(likelihood + 1e-12)
            log_posteriors[disease] = log_p

        # Numerically stable softmax (log-sum-exp trick)
        max_log  = max(log_posteriors.values())
        exp_vals = {d: np.exp(v - max_log) for d, v in log_posteriors.items()}
        total    = sum(exp_vals.values())
        return {d: round(v / total, 6) for d, v in exp_vals.items()}

    # ── Shannon Entropy ──────────────────────────────────────
    def compute_entropy(self, posteriors: Dict[str, float]) -> float:
        """
        H(D|S) = -∑ P(D|S) log₂ P(D|S)

        Higher entropy → model is more uncertain
        Maximum entropy (uniform) → log₂(K) where K = num diseases
        """
        probs = np.array(list(posteriors.values()))
        probs = probs[probs > 0]
        return float(-np.sum(probs * np.log2(probs)))

    # ── Prior Updating from Patient History ──────────────────
    def update_priors_from_history(
        self, history: List[str]
    ) -> Dict[str, float]:
        """
        Adjust priors based on patient medical history.
        Uses simple multiplicative updates (pseudo-Bayesian).

        Example: history=['diabetes'] → boost diabetes prior
        """
        updated = dict(self.priors)
        boost_map = {
            'diabetes':   {'diabetes': 3.0, 'cardiac': 1.5},
            'hypertension':{'cardiac': 2.5},
            'smoking':    {'cardiac': 2.0, 'flu': 1.3, 'covid19': 1.3},
            'travel':     {'dengue': 3.0, 'covid19': 1.5},
            'vaccination': {'flu': 0.3, 'covid19': 0.3},
        }
        for condition in history:
            condition = condition.lower()
            if condition in boost_map:
                for disease, factor in boost_map[condition].items():
                    updated[disease] = updated.get(disease, 0) * factor

        # Renormalize
        total = sum(updated.values())
        return {d: v / total for d, v in updated.items()}

    # ── Risk Stratification ───────────────────────────────────
    def _get_risk_level(self, diagnosis: str, confidence: float) -> str:
        if diagnosis in self.HIGH_RISK_DISEASES and confidence > 0.3:
            return "🔴 HIGH RISK"
        elif diagnosis in self.MEDIUM_RISK_DISEASES and confidence > 0.4:
            return "🟡 MEDIUM RISK"
        elif diagnosis == 'healthy':
            return "🟢 LOW RISK"
        else:
            return "🟡 MEDIUM RISK"

    # ── Explanation Generator ─────────────────────────────────
    def explain(self, disease: str, symptoms: List[str]) -> str:
        """
        Human-readable breakdown of the posterior calculation.
        """
        symptoms = [s.lower().replace(' ', '_') for s in symptoms]
        prior    = self.priors.get(disease, 0)
        parts    = [f"P({disease}) = {prior:.3f}"]
        for s in symptoms:
            lk = self.likelihoods[disease].get(s, self.alpha)
            w  = self.CRITICAL_WEIGHTS.get(s, 1.0)
            wt = f" [weight×{w}]" if w != 1.0 else ""
            parts.append(f"P({s}|{disease}) = {lk:.2f}{wt}")
        return "\n    ".join(parts)

    # ── Symptom Contribution Analysis ────────────────────────
    def symptom_contributions(
        self, symptoms: List[str], disease: str
    ) -> Dict[str, float]:
        """
        For each symptom, compute how much it shifts the posterior
        compared to using no symptoms. Returns normalized contributions.
        """
        symptoms = [s.lower().replace(' ', '_') for s in symptoms]
        contribs = {}
        for s in symptoms:
            lk   = self.likelihoods[disease].get(s, self.alpha)
            w    = self.CRITICAL_WEIGHTS.get(s, 1.0)
            contribs[s] = w * np.log(lk + 1e-12)
        # Shift to positive for display
        min_c = min(contribs.values())
        contribs = {s: v - min_c for s, v in contribs.items()}
        total = sum(contribs.values()) + 1e-12
        return {s: round(v / total, 4) for s, v in contribs.items()}

    # ── Differential Diagnosis ───────────────────────────────
    def differential_diagnosis(
        self, symptoms: List[str], top_k: int = 3
    ) -> List[Tuple[str, float, str]]:
        """
        Returns top-k diagnoses with their confidence and key
        distinguishing symptom for each.
        """
        posteriors = self.compute_posterior(symptoms)
        ranked     = sorted(posteriors.items(), key=lambda x: x[1], reverse=True)
        result     = []
        for disease, prob in ranked[:top_k]:
            # Find the single strongest symptom for this disease
            lk_dict  = self.likelihoods.get(disease, {})
            clean_sx = [s.lower().replace(' ', '_') for s in symptoms]
            if clean_sx:
                key_sx = max(clean_sx, key=lambda s: lk_dict.get(s, 0))
            else:
                key_sx = "N/A"
            result.append((disease, prob, key_sx))
        return result

    # ── Main Analyze Interface ────────────────────────────────
    def analyze(self, percept: Percept) -> DiagnosisResult:
        """
        Full diagnostic pipeline:
        1. Optionally update priors from history
        2. Compute posterior
        3. Compute uncertainty (entropy)
        4. Generate explanation and risk level
        5. Return structured DiagnosisResult
        """
        # Step 1: History-adjusted priors
        custom_priors = None
        if percept.history:
            custom_priors = self.update_priors_from_history(percept.history)

        # Step 2: Posterior inference
        posteriors = self.compute_posterior(
            percept.symptoms, custom_priors=custom_priors
        )

        # Step 3: Rank and extract top
        ranked    = sorted(posteriors.items(), key=lambda x: x[1], reverse=True)
        top_d, top_p = ranked[0]

        # Step 4: Uncertainty
        entropy   = self.compute_entropy(posteriors)
        max_entropy = np.log2(len(self.priors))  # Uniform case

        # Step 5: Risk + recommendations
        risk_level    = self._get_risk_level(top_d, top_p)
        recommendations = self.RECOMMENDATIONS.get(top_d, ["Consult a physician"])

        # Step 6: Explanation
        explanation = self.explain(top_d, percept.symptoms)

        result = DiagnosisResult(
            patient_id       = percept.patient_id,
            symptoms         = percept.symptoms,
            top_diagnosis    = top_d,
            confidence       = top_p,
            all_posteriors   = posteriors,
            ranked_diagnoses = ranked,
            explanation      = explanation,
            risk_level       = risk_level,
            recommendations  = recommendations,
            uncertainty      = round(entropy, 4),
        )
        self._history.append(result)
        return result

    # ── Batch Diagnosis ──────────────────────────────────────
    def batch_analyze(self, percepts: List[Percept]) -> List[DiagnosisResult]:
        """Process multiple patients at once."""
        return [self.analyze(p) for p in percepts]

    # ── Sensitivity Analysis ─────────────────────────────────
    def sensitivity_analysis(
        self, base_symptoms: List[str], test_symptom: str
    ) -> Dict[str, float]:
        """
        How much does adding `test_symptom` shift posteriors?
        Returns delta P(D) for each disease.
        """
        before = self.compute_posterior(base_symptoms)
        after  = self.compute_posterior(base_symptoms + [test_symptom])
        return {d: round(after[d] - before[d], 4) for d in self.priors}


