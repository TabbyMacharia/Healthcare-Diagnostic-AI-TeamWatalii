@dataclass
class Percept:
    """
    Represents a patient's observed symptoms and metadata.
    Used as the input interface for the diagnostic agent.
    """
    symptoms:       List[str]
    patient_id:     str  = "P001"
    age:            int  = 30
    gender:         str  = "unknown"
    history:        List[str] = field(default_factory=list)

    def __post_init__(self):
        # Normalize symptom strings
        self.symptoms = [s.lower().replace(' ', '_') for s in self.symptoms]

    def __repr__(self):
        return (f"Percept(patient={self.patient_id}, "
                f"age={self.age}, symptoms={self.symptoms})")


@dataclass
class DiagnosisResult:
    """
    Full structured output from the diagnostic system.
    """
    patient_id:       str
    symptoms:         List[str]
    top_diagnosis:    str
    confidence:       float
    all_posteriors:   Dict[str, float]
    ranked_diagnoses: List[Tuple[str, float]]
    explanation:      str
    risk_level:       str
    recommendations:  List[str]
    uncertainty:      float   # Entropy of posterior distribution

    def summary(self) -> str:
        lines = [
            f"\n{'='*60}",
            f"  🏥 DIAGNOSTIC REPORT — Patient {self.patient_id}",
            f"{'='*60}",
            f"  Symptoms     : {', '.join(self.symptoms)}",
            f"  Top Diagnosis: {self.top_diagnosis.upper()} ({self.confidence:.2%})",
            f"  Risk Level   : {self.risk_level}",
            f"  Uncertainty  : {self.uncertainty:.4f} (entropy)",
            f"\n  📊 Top 5 Ranked Diagnoses:",
        ]
        for i, (d, p) in enumerate(self.ranked_diagnoses[:5], 1):
            bar = '█' * int(p * 40)
            lines.append(f"    {i}. {d:<20} {p:.2%}  {bar}")
        lines.append(f"\n  🔍 Explanation:\n    {self.explanation}")
        lines.append(f"\n  💊 Recommendations:")
        for r in self.recommendations:
            lines.append(f"    • {r}")
        lines.append(f"{'='*60}")
        return '\n'.join(lines)


