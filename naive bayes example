class DiagnosticsVisualizer:
    """
    Complete visualization suite for the Bayesian diagnostic system.
    """

    DISEASE_COLORS = {
        'flu':          '#3498DB',
        'covid19':      '#E74C3C',
        'dengue':       '#F39C12',
        'cardiac':      '#C0392B',
        'diabetes':     '#9B59B6',
        'common_cold':  '#2ECC71',
        'healthy':      '#1ABC9C',
    }

    @staticmethod
    def plot_posterior(result: DiagnosisResult, ax=None):
        """Horizontal bar chart of posterior probabilities."""
        if ax is None:
            _, ax = plt.subplots(figsize=(10, 5))

        ranked = result.ranked_diagnoses
        names  = [r[0] for r in ranked]
        probs  = [r[1] for r in ranked]
        colors = [DiagnosticsVisualizer.DISEASE_COLORS.get(n, '#95A5A6')
                  for n in names]

        bars = ax.barh(names[::-1], probs[::-1], color=colors[::-1],
                       edgecolor='white', linewidth=0.8)
        for bar, prob in zip(bars, probs[::-1]):
            ax.text(bar.get_width() + 0.005, bar.get_y() + bar.get_height()/2,
                    f'{prob:.2%}', va='center', fontsize=9, fontweight='bold')

        ax.axvline(x=result.confidence, color='red', linestyle='--',
                   alpha=0.5, label=f'Top confidence: {result.confidence:.2%}')
        ax.set_xlim(0, 1.1)
        ax.set_xlabel('Posterior Probability P(D | Symptoms)', fontsize=10)
        ax.set_title(f'Diagnostic Posterior — Patient {result.patient_id}',
                     fontsize=12, fontweight='bold')
        ax.legend(fontsize=8)
        ax.grid(axis='x', alpha=0.3)
        return ax

    @staticmethod
    def plot_symptom_contributions(
        engine: SimpleBayesianDiagnostics,
        result: DiagnosisResult,
        ax=None
    ):
        """Show how each symptom contributed to the top diagnosis."""
        if ax is None:
            _, ax = plt.subplots(figsize=(8, 5))

        contribs = engine.symptom_contributions(
            result.symptoms, result.top_diagnosis
        )
        sorted_c = sorted(contribs.items(), key=lambda x: x[1], reverse=True)
        names    = [c[0] for c in sorted_c]
        vals     = [c[1] for c in sorted_c]

        cmap   = plt.cm.RdYlGn
        colors = [cmap(v) for v in vals]
        ax.bar(names, vals, color=colors, edgecolor='white')
        ax.set_title(f"Symptom Contributions → {result.top_diagnosis.upper()}",
                     fontsize=11, fontweight='bold')
        ax.set_ylabel("Normalized Contribution")
        ax.set_xticklabels(names, rotation=30, ha='right', fontsize=9)
        ax.grid(axis='y', alpha=0.3)
        return ax

    @staticmethod
    def plot_uncertainty_gauge(result: DiagnosisResult, ax=None):
        """Semicircle gauge showing uncertainty level."""
        if ax is None:
            _, ax = plt.subplots(figsize=(6, 4))

        max_entropy = np.log2(7)  # 7 diseases
        uncertainty_pct = result.uncertainty / max_entropy

        theta    = np.linspace(0, np.pi, 300)
        r_outer, r_inner = 1.0, 0.6

        # Background arc
        ax.fill_between(np.cos(theta), np.sin(theta) * r_inner,
                        np.sin(theta) * r_outer, color='#ECF0F1', alpha=0.5)

        # Filled arc for uncertainty
        fill_theta = np.linspace(0, np.pi * uncertainty_pct, 300)
        color = '#E74C3C' if uncertainty_pct > 0.6 else \
                '#F39C12' if uncertainty_pct > 0.35 else '#2ECC71'
        ax.fill_between(np.cos(fill_theta),
                        np.sin(fill_theta) * r_inner,
                        np.sin(fill_theta) * r_outer,
                        color=color, alpha=0.85)

        ax.set_xlim(-1.3, 1.3)
        ax.set_ylim(-0.2, 1.2)
        ax.set_aspect('equal')
        ax.axis('off')
        ax.text(0, 0.05, f'{uncertainty_pct:.0%}', ha='center', va='center',
                fontsize=22, fontweight='bold', color=color)
        ax.text(0, -0.15, 'Uncertainty', ha='center', fontsize=10, color='gray')
        ax.set_title('Diagnostic Uncertainty', fontsize=11, fontweight='bold')
        return ax

    @staticmethod
    def plot_sensitivity(
        engine: SimpleBayesianDiagnostics,
        base_symptoms: List[str],
        test_symptom: str,
        ax=None
    ):
        """Show posterior shift when a new symptom is added."""
        if ax is None:
            _, ax = plt.subplots(figsize=(10, 5))

        deltas  = engine.sensitivity_analysis(base_symptoms, test_symptom)
        sorted_d = sorted(deltas.items(), key=lambda x: x[1], reverse=True)
        names    = [s[0] for s in sorted_d]
        vals     = [s[1] for s in sorted_d]
        colors   = ['#E74C3C' if v > 0 else '#3498DB' for v in vals]

        ax.bar(names, vals, color=colors, edgecolor='white')
        ax.axhline(0, color='black', linewidth=0.8)
        ax.set_title(f"Posterior Shift After Adding: '{test_symptom}'",
                     fontsize=11, fontweight='bold')
        ax.set_ylabel("ΔP(Disease)")
        ax.set_xticklabels(names, rotation=30, ha='right', fontsize=9)
        ax.grid(axis='y', alpha=0.3)

        red_p  = mpatches.Patch(color='#E74C3C', label='Probability ↑')
        blue_p = mpatches.Patch(color='#3498DB', label='Probability ↓')
        ax.legend(handles=[red_p, blue_p], fontsize=9)
        return ax

    @classmethod
    def full_report(
        cls,
        engine: SimpleBayesianDiagnostics,
        result: DiagnosisResult,
        sensitivity_symptom: Optional[str] = None
    ):
        """Generate a complete 2×2 diagnostic dashboard."""
        fig = plt.figure(figsize=(18, 12))
        fig.patch.set_facecolor('#F8F9FA')
        gs  = gridspec.GridSpec(2, 2, figure=fig,
                                hspace=0.4, wspace=0.35)

        ax1 = fig.add_subplot(gs[0, 0])
        ax2 = fig.add_subplot(gs[0, 1])
        ax3 = fig.add_subplot(gs[1, 0])
        ax4 = fig.add_subplot(gs[1, 1])

        cls.plot_posterior(result, ax1)
        cls.plot_symptom_contributions(engine, result, ax2)
        cls.plot_uncertainty_gauge(result, ax3)

        if sensitivity_symptom:
            cls.plot_sensitivity(engine, result.symptoms,
                                 sensitivity_symptom, ax4)
        else:
            # Likelihood heatmap across diseases for reported symptoms
            sx_clean = [s.lower().replace(' ','_') for s in result.symptoms]
            diseases = list(engine.priors.keys())
            matrix   = np.array([
                [engine.likelihoods[d].get(s, engine.alpha)
                 for s in sx_clean]
                for d in diseases
            ])
            im = ax4.imshow(matrix, cmap='YlOrRd', aspect='auto',
                            vmin=0, vmax=1)
            ax4.set_xticks(range(len(sx_clean)))
            ax4.set_xticklabels(sx_clean, rotation=35, ha='right', fontsize=8)
            ax4.set_yticks(range(len(diseases)))
            ax4.set_yticklabels(diseases, fontsize=9)
            for i in range(len(diseases)):
                for j in range(len(sx_clean)):
                    ax4.text(j, i, f'{matrix[i,j]:.2f}',
                             ha='center', va='center', fontsize=7,
                             color='black' if matrix[i,j] < 0.7 else 'white')
            plt.colorbar(im, ax=ax4, fraction=0.046, pad=0.04)
            ax4.set_title('Likelihood Heatmap P(S|D)', fontsize=11,
                          fontweight='bold')

        fig.suptitle(
            f"🏥 Bayesian Diagnostic Dashboard  |  "
            f"Patient: {result.patient_id}  |  "
            f"Top Dx: {result.top_diagnosis.upper()} ({result.confidence:.1%})",
            fontsize=13, fontweight='bold', y=1.01
        )
        plt.savefig("diagnostic_dashboard.png", dpi=150,
                    bbox_inches='tight', facecolor=fig.get_facecolor())
        plt.show()
        print("✅ Dashboard saved → diagnostic_dashboard.png")


